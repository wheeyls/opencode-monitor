# Google OAuth 2.0 (GCP console → Internal consent screen → Web application)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Random secret for session cookie HMAC. Generate: openssl rand -base64 32
SESSION_SECRET=

# Postgres connection string. Omit to use in-memory storage (dev only).
# DATABASE_URL=postgresql://user:password@localhost:5432/arb

# Dev-only: skip Google OAuth. Has no effect when NODE_ENV=production.
# DEV_BYPASS_AUTH=true
